NODE_ENV=production
PORT=5000

# Railway/PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend/backend URLs
FRONTEND_URL=https://kudisave.com
BACKEND_URL=https://kudisave-api-production.up.railway.app

# Google sign-in / Gmail OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://kudisave-api-production.up.railway.app/api/v1/gmail/callback

# Email. Prefer Resend on Railway; SMTP is fallback.
RESEND_API_KEY=
EMAIL_FROM=KudiSave <support@kudisave.com>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
